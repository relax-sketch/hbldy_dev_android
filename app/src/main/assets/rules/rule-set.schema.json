{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grassland-quality.local/schema/rule-set.schema.json",
  "title": "Embedded grassland quality-check rule set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "ruleSetVersion",
    "publishedAt",
    "sources",
    "rules"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "ruleSetVersion": {
      "type": "string",
      "minLength": 1
    },
    "publishedAt": {
      "type": "string",
      "format": "date"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "BASE_SNAPSHOT",
            "ADDITIONAL"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceId",
        "severity",
        "targetTable",
        "title",
        "explanation",
        "requiredTables",
        "requiredFields",
        "locatorFields",
        "sql"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "MANDATORY",
            "ADVISORY"
          ]
        },
        "targetTable": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "requiredTables": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "locatorFields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sql": {
          "type": "string",
          "minLength": 1,
          "description": "A scoped single SELECT or WITH...SELECT query; SQL safety is validated separately."
        }
      }
    }
  }
}
